{
  "name": "asap-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project ./tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "start:prod": "npm run migrate && npm run start",
    "discord:test": "tsx src/discord/tester.ts",
    "discord:test:channels": "tsx src/discord/channelCompletionCheck.ts",
    "discord:test:channels:batch": "tsx src/discord/channelCompletionCheck.ts --batch-size=4 --timeout-ms=90000 --retries=1 --inter-agent-stagger-ms=200 --inter-batch-delay-ms=600",
    "discord:test:channels:fast": "tsx src/discord/channelCompletionCheck.ts --batch-size=6 --timeout-ms=60000 --retries=1 --inter-agent-stagger-ms=120 --inter-batch-delay-ms=300",
    "discord:test:dist": "node dist/discord/tester.js",
    "discord:test:fast": "DISCORD_SMOKE_PROFILE=readiness DISCORD_TEST_TIMEOUT_MS=20000 DISCORD_SMOKE_CAPABILITY_ATTEMPTS=2 DISCORD_SMOKE_PRE_CLEAR=false DISCORD_SMOKE_POLL_INTERVAL_MS=900 DISCORD_SMOKE_ELEVENLABS_VOICE_BRIDGE=false DISCORD_SMOKE_VOICE_ACTIVE_CALL=false node dist/discord/tester.js",
    "discord:test:fast:with-runtime": "bash ./scripts/discord-smoke-fast.sh",
    "discord:test:full": "DISCORD_SMOKE_PRE_CLEAR=true node dist/discord/tester.js",
    "discord:test:readiness": "DISCORD_SMOKE_PROFILE=readiness DISCORD_TEST_TIMEOUT_MS=30000 DISCORD_SMOKE_CAPABILITY_ATTEMPTS=2 DISCORD_SMOKE_ELEVENLABS_VOICE_BRIDGE=false node dist/discord/tester.js",
    "anthropic:usage:snapshot": "node scripts/anthropic-usage-report.mjs snapshot",
    "anthropic:usage:report": "node scripts/anthropic-usage-report.mjs diff",
    "visual:baseline": "tsx src/services/visualRegression.ts baseline",
    "visual:check": "tsx src/services/visualRegression.ts check",
    "db:grant-agent-memory": "tsx src/db/checkAndGrantAgentMemoryPerms.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:api": "if [ -f openapi.yaml ]; then spectral lint openapi.yaml; else echo 'openapi.yaml not found (skip)'; fi",
    "security:audit": "npm audit --audit-level=high",
    "security:semgrep": "npx --yes @semgrep/cli semgrep --config=auto --error --exclude node_modules src",
    "quality": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@google-cloud/storage": "^7.15.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "elevenlabs": "^1.59.0",
    "express": "^4.21.2",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.3",
    "opusscript": "^0.0.8",
    "pg": "^8.13.1",
    "prism-media": "^1.3.5",
    "puppeteer": "^24.40.0",
    "sodium-native": "^5.1.0",
    "tweetnacl": "^1.0.3",
    "twilio": "^5.13.1",
    "uuid": "^11.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.25.4",
    "@stoplight/prism-cli": "^5.14.2",
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "artillery": "^2.0.30",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^30.3.0",
    "jest-image-snapshot": "^6.5.2",
    "msw": "^2.12.14",
    "newman": "^6.2.2",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2"
  }
}
