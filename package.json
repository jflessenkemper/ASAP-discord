{
  "name": "asap-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "discord:test": "tsx src/discord/tester.ts",
    "discord:test:dist": "node dist/discord/tester.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:api": "if [ -f openapi.yaml ]; then spectral lint openapi.yaml; else echo 'openapi.yaml not found (skip)'; fi",
    "security:audit": "npm audit --audit-level=high",
    "security:semgrep": "npx --yes @semgrep/cli semgrep --config=auto --error --exclude node_modules src",
    "quality": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@deepgram/sdk": "^3.13.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@google-cloud/storage": "^7.15.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "apple-signin-auth": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "elevenlabs": "^1.59.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.3",
    "opusscript": "^0.0.8",
    "pg": "^8.13.1",
    "prism-media": "^1.3.5",
    "puppeteer": "^24.40.0",
    "sodium-native": "^5.1.0",
    "tweetnacl": "^1.0.3",
    "twilio": "^5.13.1",
    "uuid": "^11.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.15.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-security": "^4.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2"
  }
}
