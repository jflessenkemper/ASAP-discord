# ╔══════════════════════════════════════════════════════════════════════╗
# ║ ASAP Discord Bot — Environment Variables                            ║
# ║ Copy to .env and fill in required values.                           ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Core Runtime ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
SERVER_URL=http://localhost:8080
JWT_SECRET=

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/asap
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=asap
# DB_USER=user
# DB_PASSWORD=
# DB_SSL_MODE=disable
# DB_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_CA_CERT=
# DATABASE_CA_CERT_BASE64=
# DATABASE_CA_CERT_FILE=
# PGSSLROOTCERT=

# ── Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_ENABLED=true
DISCORD_GUILD_ID=
# DISCORD_BOT_LOCK_KEY=
# DISCORD_BOT_SKIP_LOCK=false

# ── AI / LLM ────────────────────────────────────────────────────────
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_ADMIN_API_KEY=
# GEMINI_USE_VERTEX_AI=false
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_TTS_MODEL_ID=
# ── ElevenLabs Conversational AI (Cortana agent) ───────────────────
# When ELEVENLABS_CONVAI_AGENT_ID is set and ENABLED=true, live voice
# calls route through the Convai agent (system prompt, KB, guardrails
# configured in the ElevenLabs dashboard). When unset, the bot falls
# back to the legacy text-first voice path.
# ELEVENLABS_CONVAI_ENABLED=true
# ELEVENLABS_CONVAI_AGENT_ID=agent_1001kpw8pymkftk82apxgy32njmt

# ── GitHub ───────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# ── GCP / Cloud Run ─────────────────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=
# CLOUD_RUN_REGION=australia-southeast1
# CLOUD_RUN_SERVICE=asap
# GCS_BUCKET_NAME=
# GCS_PROJECT_ID=

# ── Job Search ───────────────────────────────────────────────────────
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# ── Telephony (Twilio) ──────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Google Maps / Apple Maps ────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=
# APPLE_TEAM_ID=
# APPLE_SERVICE_ID=
# APPLE_MAPKIT_KEY_ID=
# APPLE_MAPKIT_PRIVATE_KEY=

# ── Fuel Tracking ───────────────────────────────────────────────────
# FUEL_API_KEY=
# FUEL_CONSUMPTION_L_PER_100KM=8.5

# ── Email ────────────────────────────────────────────────────────────
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# ── Agent / Bot Tuning ──────────────────────────────────────────────
# AGENT_REPO_ROOT=
# STRICT_AGENT_TOOL_ACCESS=true
# GUARDRAILS_ENABLED=true
# TEXT_MAX_TOKENS_STANDARD=4096
# TEXT_MAX_TOKENS_DEVELOPER=8192
# TEXT_MAX_TOKENS_SIMPLE=1024
# TEXT_AGENT_RESPONSE_TIMEOUT_MS=120000

# ── Smoke Testing ───────────────────────────────────────────────────
# DISCORD_TEST_BOT_TOKEN=
# DISCORD_TEST_TIMEOUT_MS=60000
# DISCORD_SMOKE_PROFILE=readiness
